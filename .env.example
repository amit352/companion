# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Services (defaults match docker-compose.yml) ──────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=feature-graph-dev

POSTGRES_DSN=postgresql://featuregraph:featuregraph-dev@localhost:5432/featuregraph

REDIS_URL=redis://localhost:6379

# ── Analysis tuning (optional) ────────────────────────────────────────────────
MAX_CONCURRENT_ANALYZERS=5
FILE_BATCH_SIZE=20

# ── Observability (optional) ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=feature-graph-api
