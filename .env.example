# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Services (defaults match docker-compose.yml) ──────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=companion-dev

POSTGRES_DSN=postgresql://companion:companion-dev@localhost:5432/featuregraph

REDIS_URL=redis://localhost:6379

# ── Analysis tuning (optional) ────────────────────────────────────────────────
MAX_CONCURRENT_ANALYZERS=5
FILE_BATCH_SIZE=20

# ── GitHub webhook (Phase 6) ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# JSON map of GitHub repo full names to local clone paths
# Example: {"owner/repo": "/Users/you/code/repo"}
GITHUB_REPO_PATHS={}

# ── Observability (optional) ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=companion-api
